# ──────────────────────────────────────────────────────────────
#  Variáveis de Ambiente — Backend MegaCripto
#  Copie este arquivo para .env e preencha com valores reais.
# ──────────────────────────────────────────────────────────────

# ─── Mercado Pago ───────────────────────────────────────────────
# Access Token da conta MP (use o token de PRODUÇÃO em prod)
# Obtenha em: https://www.mercadopago.com.br/developers/panel
MP_ACCESS_TOKEN=APP_USR-0000000000000000-000000-00000000000000000000000000000000-000000000

# URL pública do webhook (precisa ser acessível pela internet)
# Use ngrok em dev: ngrok http 3000 → https://abc123.ngrok.io/webhook/mercadopago
MP_WEBHOOK_URL=https://seu-dominio.com/webhook/mercadopago

# ─── Solana ─────────────────────────────────────────────────────
# Caminho para o arquivo JSON do keypair do servidor (server_authority)
# Gerado com: solana-keygen new --outfile ~/.config/solana/mega-cripto-server.json
SOLANA_KEYPAIR_PATH=/home/user/.config/solana/mega-cripto-server.json

# URL do RPC Solana (Devnet para testes, Mainnet para produção)
# Devnet:  https://api.devnet.solana.com
# Mainnet: https://api.mainnet-beta.solana.com
# Helius:  https://rpc.helius.xyz/?api-key=SEU_API_KEY
SOLANA_RPC_URL=https://api.devnet.solana.com

# ─── Servidor ───────────────────────────────────────────────────
PORT=3000
