# Server Configuration
PORT=3000

# Solana Configuration
SOLANA_RPC_URL="https://api.devnet.solana.com"
SOLANA_KEYPAIR_PATH="./server-keypair.json"

# Mercado Pago Configuration (Payouts and Payments)
# Token de acesso do Mercado Pago (Inicia com APP_USR- ou TEST-)
MP_ACCESS_TOKEN="TEST-000000000000000-000000-00000000000000000000000000000000-000000000"
MP_WEBHOOK_URL="https://seu-dominio.com/webhook/mercadopago"

# KYC / Onboarding Configuration
# Valores possíveis: "SIMULATED", "REAL"
KYC_MODE="SIMULATED"

# Integração BigData Corp
BIGDATACORP_API_KEY=""
BIGDATACORP_API_URL="https://api.bigdatacloud.net/data/cpf-data"

# Logging
RUST_LOG=info
